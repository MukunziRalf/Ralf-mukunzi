{
  "schemaVersion": 1,
  "entities": {
    "triage_history": {
      "title": "Triage History",
      "description": "Saved patient symptom triage logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "toothNum": { "type": "number" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "urgency": { "type": "string" },
        "triageNotes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "createdAt"]
    },
    "soap_notes": {
      "title": "SOAP Notes",
      "description": "Clinician SOAP notes and treatment plans",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "patientName": { "type": "string" },
        "subjective": { "type": "string" },
        "objective": { "type": "string" },
        "assessment": { "type": "string" },
        "plan": { "type": "string" },
        "toothNum": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "patientName", "createdAt"]
    }
  }
}
